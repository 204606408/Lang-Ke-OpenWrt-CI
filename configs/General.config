### 通用配置文件
# 兆能M2 | 普通家用路由 | 稳定精简 
# ==================== 编译基础优化 ====================
CONFIG_DEVEL=n                               # 关闭开发者调试模式，更稳定、固件更小
CONFIG_TARGET_OPTIONS=y                      # 启用CPU平台性能优化
CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -march=armv8-a+crypto+crc -mcpu=cortex-a53+crypto+crc -mtune=cortex-a53"
CONFIG_CCACHE=y                              # 开启编译缓存，云端二次编译更快
CONFIG_TARGET_PER_DEVICE_ROOTFS=n            # 仅生成兆能M2单个设备镜像

# ==================== 系统基础配置 ====================
CONFIG_PACKAGE_default-settings=y            # 启用系统基础默认配置
CONFIG_PACKAGE_default-settings-chn=y        # 启用中国区默认设置（时区、NTP等）

# ==================== 内核相关 ====================
# CONFIG_FEED_nss_packages is not set        # NSS源由ImmortalWrt自带处理
# CONFIG_FEED_sqm_scripts_nss is not set     # 不使用NSS硬件加速QoS
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set  # 不生成initramfs格式固件

# ==================== ZRAM内存压缩优化 ====================
CONFIG_PACKAGE_zram-swap=y                   # 启用ZRAM内存交换，缓解内存压力
CONFIG_PACKAGE_kmod-lib-lz4=y                # 启用LZ4高速压缩算法
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y             # ZRAM使用LZ4作为压缩后端
CONFIG_KERNEL_ZRAM_BACKEND_LZO=y             # 保留LZO作为备用压缩算法
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y            # 默认压缩算法设置为LZ4

# ==================== 基础系统工具 ====================
#CONFIG_PACKAGE_tmux=n                        # 禁用多终端复用工具
CONFIG_PACKAGE_dmesg=y                       # 保留内核日志查看工具
CONFIG_PACKAGE_htop=y                        # 保留进程与资源监控工具
#CONFIG_PACKAGE_btop=n                        # 禁用高级资源监控工具
CONFIG_PACKAGE_nano-full=y                   # 保留简易命令行文本编辑器
CONFIG_PACKAGE_autocore=y                    # 保留CPU/温度自动识别支持
#CONFIG_PACKAGE_coremark=n                    # 禁用CPU性能跑分工具
CONFIG_PACKAGE_zoneinfo-asia=y               # 保留亚洲时区信息

# ==================== Luci界面主题 ====================
CONFIG_PACKAGE_luci-theme-argon=y            # 启用Argon简洁主题
CONFIG_PACKAGE_luci-app-argon-config=y       # 启用Argon主题设置界面

# ==================== 路由常用基础功能 ====================
CONFIG_PACKAGE_luci-app-cpufreq=y            # 启用CPU调频，省电降温
CONFIG_PACKAGE_luci-app-ttyd=y               # 启用网页终端，方便调试
CONFIG_PACKAGE_luci-app-upnp=y               # 启用UPnP（普通路由标准功能）
CONFIG_PACKAGE_luci-app-wolplus=y            # 启用网络唤醒功能
CONFIG_PACKAGE_luci-app-autoreboot=y         # 启用定时自动重启
CONFIG_PACKAGE_luci-app-arpbind=y            # 启用IP/MAC绑定，防冲突

# ==================== 原生QoS（普通路由必备） ====================
CONFIG_PACKAGE_sqm-scripts=y                # 启用普通版SQM限速核心
CONFIG_PACKAGE_luci-app-sqm=y               # 启用SQM网页设置界面

# ==================== 原生DDNS ====================
CONFIG_PACKAGE_luci-app-ddns=y               # 启用原生DDNS网页管理界面
CONFIG_PACKAGE_ddns-scripts=y                # 启用原生DDNS核心脚本
CONFIG_PACKAGE_ddns-scripts-cloudflare=y     # 启用Cloudflare DDNS支持

# ==================== 代理 / 解锁类 ====================
CONFIG_PACKAGE_luci-app-unblockneteasemusic=y# 启用网易云音乐解锁
#CONFIG_PACKAGE_luci-app-homeproxy=n          # 禁用代理插件
#CONFIG_PACKAGE_luci-app-openclash=n          # 禁用代理插件

# ==================== VPN支持 ====================
CONFIG_PACKAGE_luci-proto-wireguard=y        # 保留WireGuard VPN支持

# ==================== 不常用功能禁用 ====================
#CONFIG_PACKAGE_luci-app-banip=n              # 禁用IP黑名单防火墙
#CONFIG_PACKAGE_luci-app-oaf=n                # 禁用应用过滤
#CONFIG_PACKAGE_luci-app-wechatpush=n         # 禁用微信消息推送
#CONFIG_PACKAGE_luci-app-watchcat=n           # 禁用系统看门狗

# ==================== 链路聚合（LAN 口绑定）====================
#CONFIG_PACKAGE_kmod-bonding=n               # 启用端口聚合内核模块
#CONFIG_PACKAGE_luci-app-bonding=n           # 网页配置链路聚合

# ==================== 多宽带叠加 / 多线负载 ====================
#CONFIG_PACKAGE_mwan3=n                      # 多线策略路由核心
#CONFIG_PACKAGE_luci-app-mwan3=n             # 多线叠加网页设置
#CONFIG_PACKAGE_mwan3-tools=n                # 多线调试工具
