# 编译优化
CONFIG_DEVEL=n                              # 关闭开发者模式，更稳定
CONFIG_TARGET_OPTIONS=y                     # 启用CPU性能优化
CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -march=armv8-a+crypto+crc -mcpu=cortex-a53+crypto+crc -mtune=cortex-a53"
CONFIG_CCACHE=y                             # 开启编译缓存，加速二次编译
CONFIG_TARGET_PER_DEVICE_ROOTFS=n           # 仅生成当前设备固件

# 系统基础
CONFIG_PACKAGE_default-settings=y           # 启用系统默认配置
CONFIG_PACKAGE_default-settings-chn=y       # 启用中国区默认设置

# ZRAM内存压缩
CONFIG_PACKAGE_zram-swap=y                  # 启用内存压缩交换
CONFIG_PACKAGE_kmod-lib-lz4=y               # 启用LZ4压缩算法
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y            # ZRAM使用LZ4压缩
CONFIG_KERNEL_ZRAM_BACKEND_LZO=y            # 备用LZO压缩
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y           # 默认使用LZ4压缩

# 基础系统工具
CONFIG_PACKAGE_tmux=n                       # 禁用多终端工具
CONFIG_PACKAGE_dmesg=y                      # 保留系统日志工具
CONFIG_PACKAGE_htop=y                       # 保留进程监控工具
CONFIG_PACKAGE_btop=n                       # 禁用高级监控
CONFIG_PACKAGE_nano-full=y                  # 保留命令行编辑器
CONFIG_PACKAGE_autocore=y                   # 保留CPU自动识别
CONFIG_PACKAGE_coremark=n                   # 禁用跑分工具
CONFIG_PACKAGE_zoneinfo-asia=y              # 保留亚洲时区

# QoS 网速限速
CONFIG_PACKAGE_sqm-scripts=y               # 启用SQM QoS核心
CONFIG_PACKAGE_luci-app-sqm=y               # 启用QoS网页设置

# DDNS 动态域名
CONFIG_PACKAGE_luci-app-ddns=y              # 启用DDNS网页界面
CONFIG_PACKAGE_ddns-scripts=y               # 启用DDNS核心脚本
CONFIG_PACKAGE_ddns-scripts-cloudflare=y    # 启用Cloudflare DDNS支持

# 路由器基础功能
CONFIG_PACKAGE_luci-app-cpufreq=y           # 启用CPU调频
CONFIG_PACKAGE_luci-app-ttyd=y              # 启用网页终端
CONFIG_PACKAGE_luci-app-upnp=y              # 启用UPnP自动端口映射
CONFIG_PACKAGE_luci-app-wolplus=y           # 启用网络唤醒
CONFIG_PACKAGE_luci-app-autoreboot=y        # 启用定时重启
CONFIG_PACKAGE_luci-app-arpbind=y           # 启用IP/MAC绑定

# 界面主题
CONFIG_PACKAGE_luci-theme-argon=y           # 启用Argon主题
CONFIG_PACKAGE_luci-app-argon-config=y      # 启用Argon主题设置

# 扩展功能
CONFIG_PACKAGE_luci-app-unblockneteasemusic=y  # 启用网易云解锁
CONFIG_PACKAGE_luci-app-homeproxy=n         # 禁用代理插件
CONFIG_PACKAGE_luci-app-openclash=n         # 禁用代理插件

# VPN
CONFIG_PACKAGE_luci-proto-wireguard=y       # 保留WireGuard VPN

# 不常用功能（全部禁用）
CONFIG_PACKAGE_luci-app-banip=n             # 禁用IP过滤
CONFIG_PACKAGE_luci-app-oaf=n               # 禁用应用过滤
CONFIG_PACKAGE_luci-app-wechatpush=n        # 禁用微信推送
CONFIG_PACKAGE_luci-app-watchcat=n          # 禁用系统看门狗
