# 平台配置
CONFIG_TARGET_qualcommax=y                  # 启用高通IPQ平台架构
CONFIG_TARGET_qualcommax_ipq60xx=y          # 指定使用IPQ60xx芯片
CONFIG_TARGET_MULTI_PROFILE=y               # 启用多设备编译

# 设备型号
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y  # 兆能M2设备固件备
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_cmiot_ax18=y  # CMIOT AX18设备固件

# 无线相关（全部禁用）
CONFIG_PACKAGE_kmod-ath11k=n                # 禁用ATH11K无线驱动
CONFIG_PACKAGE_kmod-ath11k-ahci=n           # 禁用AHCI无线驱动
CONFIG_PACKAGE_kmod-ath11k-pci=n            # 禁用PCIe无线驱动
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n    # 禁用IPQ6018无线固件
CONFIG_PACKAGE_ath11k-firmware-ipq6018-ddwrt=n  # 禁用DDWRT版无线固件
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n    # 禁用QCN9074无线固件
CONFIG_PACKAGE_ath11k-firmware-qcn9074-ddwrt=n  # 禁用DDWRT版无线固件
CONFIG_PACKAGE_wpad-openssl=n               # 禁用无线认证组件
CONFIG_PACKAGE_hostapd-common=n             # 禁用AP热点相关组件

# NSS硬件加速
CONFIG_NSS_FIRMWARE_VERSION_11_4=y          # 启用NSS 11.4加速固件
